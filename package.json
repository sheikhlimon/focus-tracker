{
  "name": "focus-tracker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm --filter client build && pnpm --filter server build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "test": "pnpm -r test",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.3.0"
  },
  "lint-staged": {
    "server/**/*.{js,ts,jsx,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "client/**/*.{js,ts,jsx,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "!**/*.{js,ts,jsx,tsx}": [
      "oxfmt --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
