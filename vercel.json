{
  "buildCommand": "pnpm build",
  "outputDirectory": "client/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/index.cjs": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.cjs" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
